# Copy to .env.local for development. Set the same keys on Vercel (Production + Preview as needed).

# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Supabase → Settings → API → service_role (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Canonical public URL (production: https://buildinc.app)
NEXT_PUBLIC_SITE_URL=
